# DevForge Default Environment Configuration
# All options can be overridden by environment variables or custom profiles.

# Toggles for what packages to install
INSTALL_NODE=true
INSTALL_PYTHON=true
INSTALL_JAVA=true
INSTALL_RUST=true
INSTALL_GO=true
INSTALL_CPP=true
INSTALL_AWS=true
INSTALL_AZURE_CLI=true
INSTALL_GCLOUD_CLI=true
INSTALL_LAZYGIT=true
INSTALL_AI_CLIS=true
INSTALL_DEV_TOOLS=true
INSTALL_GIT_SSH=true

# Package Specific Versions & Configurations
NODE_VERSION="--lts"           # Pass to nvm install (e.g. --lts, 22, etc.)
PYTHON_VERSION="3.13"          # Python version for Astral uv to manage
JAVA_VERSION="21.0.4-tem"      # SDKMAN! Java version
RUST_CHANNEL="stable"          # Rustup default channel (stable, nightly)
GO_VERSION="1.22.5"            # Go installation version

# Install default libraries for software dev, AI/ML, and cyber
INSTALL_LANG_LIBS=true

# Git Settings
# These are fallback defaults only. On first run, bootstrap.sh will prompt interactively.
# On re-runs, values are read from devforge-output.json or the global git config.
GIT_USER_NAME="Developer"
GIT_USER_EMAIL="developer@example.com"

# Logging configuration
LOG_FILE="install.log"
